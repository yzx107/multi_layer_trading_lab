# Runtime
APP_ENV=dev
LOG_LEVEL=INFO
TZ=Asia/Hong_Kong

# Paths
DATA_ROOT=./data
DUCKDB_PATH=./duckdb/research.duckdb
RAW_DATA_ROOT=./data/raw
STAGING_DATA_ROOT=./data/staging
CURATED_DATA_ROOT=./data/curated
FEATURE_DATA_ROOT=./data/features
LOG_DATA_ROOT=./data/logs

# Tushare
TUSHARE_TOKEN=

# iFind
IFIND_USERNAME=
IFIND_PASSWORD=
IFIND_ACCESS_TOKEN=
IFIND_REFRESH_TOKEN=
IFIND_EVENTS_ENDPOINT=

# Futu OpenD
FUTU_HOST=127.0.0.1
FUTU_PORT=11111
FUTU_MARKET=HK
FUTU_ENV=SIMULATE
FUTU_UNLOCK_PASSWORD=

# IBKR
IBKR_HOST=127.0.0.1
IBKR_PORT=7497
IBKR_CLIENT_ID=1
IBKR_ACCOUNT=
IBKR_ENV=PAPER

# Strategy / Risk defaults
DEFAULT_BROKER_MODE=DRY_RUN
DEFAULT_KELLY_FRACTION=0.25
MAX_SINGLE_NAME_GROSS=0.1
MAX_STRATEGY_RISK_BUDGET=0.25
MAX_INTRADAY_DRAWDOWN=0.03
SIGNAL_MAX_AGE_SECONDS=300
OPEN_SLIPPAGE_HALT_BPS=35
